# Puerto dinámico (Railway lo asigna automáticamente)
# No necesitas cambiarlo, Railway lo inyecta
PORT=3000

# Futuro: si añades base de datos (PostgreSQL o SQLite en Railway)
# DATABASE_URL=postgresql://usuario:contraseña@host:puerto/dbname

# Futuro: si añades email verification
# SENDGRID_API_KEY=tu_clave_aqui
# SENDGRID_FROM_EMAIL=noreply@baccaelite.com

# Futuro: si usas JWT tokens en lugar de cookies
# JWT_SECRET=tu_clave_super_secreta_aqui
