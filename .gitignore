# Dependencias
node_modules/
package-lock.json
yarn.lock

# Variables de entorno (IMPORTANTE: nunca subes contraseñas)
.env
.env.local
.env.*.local

# Datos locales (la carpeta data/ con usuarios/sesiones)
# IMPORTANTE: ignora la carpeta completa, no los archivos dentro
# Esto evita que Railway sobrescriba el volumen en cada redeploy
/data/
*.json.bak
user.json
sessions.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Temporal
tmp/
temp/
*.tmp
